# Ruptura API Keys
# Get these for free — they make the calculator use live government data.
# Without them, the app works fine using hardcoded 2022-2024 data.

# Bureau of Labor Statistics — state median wages
# Register: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Bureau of Economic Analysis — regional price parities
# Register: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# Housing & Urban Development — rent data by ZIP code
# Register: https://www.huduser.gov/hudapi/public/register
HUD_API_KEY=

# Server port (default 3000)
PORT=3000
