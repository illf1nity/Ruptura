  "phase3a": {
    "stats": [
      {
        "number": "1,094%",
        "text": "CEO compensation has skyrocketed 1,094% since 1978. Typical worker pay? Up 26%. Same economy. Different rules.",
        "source": "Economic Policy Institute, 2025"
      },
      {
        "number": "$50 billion",
        "text": "An estimated $50 billion or more is stolen from workers each year through wage theft — unpaid overtime, minimum wage violations, and tip skimming. That exceeds all robberies, burglaries, and car thefts combined.",
        "source": "Economic Policy Institute, 2017 methodology updated 2022; FBI UCR"
      },
      {
        "number": "281 to 1",
        "text": "A CEO at a top firm now makes 281 times what a typical worker earns. In 1965, it was 21 to 1.",
        "source": "Economic Policy Institute, 2025"
      },
      {
        "number": "37%",
        "text": "37% of American adults would not cover a $400 emergency expense using cash or savings alone. The problem is not your budgeting. It is your paycheck.",
        "source": "Federal Reserve SHED, 2023"
      }
    ],
    "reframe": "They didn't ask your permission. Why are you asking for theirs?"
  },

  "phase3b": {
    "blocks": [
      {
        "question": "Am I just being picky?",
        "answer": "You're not being picky. The data shows you've earned {{worth_gap_annual}} less per year than workers with your experience in your area. That's not a feeling — it's a number."
      },
      {
        "question": "But what if my employer can't afford raises?",
        "answer": "National productivity has grown {{total_productivity_growth}} while wages grew just {{total_wage_growth}}. The money exists. The question is who gets it."
      },
      {
        "question": "What if I get fired for asking?",
        "answer": "For most private-sector workers, federal law (NLRA Section 7) protects your right to discuss wages and working conditions with coworkers. Retaliation is illegal, and there are federal processes to hold employers accountable. Government employees have separate protections under the Civil Service Reform Act. You have more legal backing than you think."
      },
      {
        "question": "Does this actually work?",
        "answer": "Union workers earn a 10% wage premium on average. In 2024, dockworkers won a 60% raise and Boeing machinists won 38%. The data is clear: asking works."
      }
    ]
  },

